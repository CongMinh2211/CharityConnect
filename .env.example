JWT_SECRET=change-this-in-local-development
INTERNAL_SERVICE_TOKEN=change-this-in-local-development
GRAFANA_ADMIN_PASSWORD=admin

# Frontend/Vercel
VITE_USE_MOCK_API=true
VITE_API_BASE_URL=/api/v1
VITE_ASSISTANT_URL=

# AI Assistant: để trống thì chatbot chỉ trả lời dữ liệu nội bộ/offline.
# ASSISTANT_PROVIDER=auto ưu tiên Anthropic nếu có ANTHROPIC_API_KEY, rồi OpenAI.
ASSISTANT_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01
ASSISTANT_RATE_LIMIT_PER_MINUTE=20

# Gmail OAuth2: để trống thì thư vẫn vào outbox nhưng không gửi thật.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
PUBLIC_WEB_URL=http://127.0.0.1:5173

# TrustChain: để trống RPC/private key thì anchor dùng LOCAL_SIMULATION.
ANCHOR_RPC_URL=
ANCHOR_PRIVATE_KEY=
ANCHOR_CHAIN_ID=11155111
ANCHOR_EXPLORER_URL=https://sepolia.etherscan.io/tx

# Security (mặc định hợp lý cho demo local)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auto-anchor scheduler (donation service)
AUTO_ANCHOR_ENABLED=1
AUTO_ANCHOR_THRESHOLD=50
AUTO_ANCHOR_MAX_AGE_HOURS=24
AUTO_ANCHOR_CHECK_SECONDS=600
