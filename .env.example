GRAFANA_ADMIN_PASSWORD=admin

# Frontend/Vercel/Render static web
# true = demo localStorage, khong can backend. false = goi gateway + backend that.
VITE_USE_MOCK_API=false
VITE_API_BASE_URL=https://charityconnect-gateway.onrender.com/api/v1
VITE_ASSISTANT_URL=https://charityconnect-gateway.onrender.com/api/v1

# Google Sign-In: cùng Web application client ID ở frontend và Identity Service.
# Tạo OAuth client loại Web application, sau đó khai báo đúng Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-one-time-password
ADMIN_NAME=Quản trị CharityConnect

# Backend deploy: tren tung service Render, dat DATABASE_URL bang database rieng cua service do.
NODE_ENV=production
PORT=
AUTO_MIGRATE_DB=1
JWT_SECRET=replace-with-a-long-random-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-token
REDIS_URL=redis://default:password@host:6379
PUBLIC_WEB_URL=https://charityconnect-7kep.onrender.com
CORS_ORIGINS=https://charityconnect-7kep.onrender.com,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https://charityconnect-[a-z0-9-]+\.onrender\.com$

# Identity Service
IDENTITY_DATABASE_URL=postgresql://user:password@host:5432/identity
DATABASE_URL=postgresql://user:password@host:5432/identity

# Campaign Service
CAMPAIGN_DATABASE_URL=postgresql://user:password@host:5432/campaign

# Donation Service
DONATION_DATABASE_URL=postgresql://user:password@host:5432/donation
CAMPAIGN_SERVICE_URL=https://charityconnect-campaign.onrender.com

# Gateway routing
IDENTITY_SERVICE_URL=https://charityconnect-identity.onrender.com
CAMPAIGN_SERVICE_URL=https://charityconnect-campaign.onrender.com
DONATION_SERVICE_URL=https://charityconnect-donation.onrender.com
ASSISTANT_SERVICE_URL=https://charityconnect-assistant.onrender.com

# AI Assistant: để trống thì chatbot chỉ trả lời dữ liệu nội bộ/offline.
# ASSISTANT_PROVIDER=auto ưu tiên Anthropic nếu có ANTHROPIC_API_KEY, rồi OpenAI.
ASSISTANT_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_WEB_SEARCH=true
ASSISTANT_RATE_LIMIT_PER_MINUTE=20

# Gmail OAuth2: để trống thì thư vẫn vào outbox nhưng không gửi thật.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# TrustChain: để trống RPC/private key thì anchor dùng LOCAL_SIMULATION.
ANCHOR_RPC_URL=
ANCHOR_PRIVATE_KEY=
ANCHOR_CHAIN_ID=11155111
ANCHOR_EXPLORER_URL=https://sepolia.etherscan.io/tx

# Security
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Auto-anchor scheduler (donation service)
AUTO_ANCHOR_ENABLED=1
AUTO_ANCHOR_THRESHOLD=50
AUTO_ANCHOR_MAX_AGE_HOURS=24
AUTO_ANCHOR_CHECK_SECONDS=600
RECONCILIATION_INTERVAL_SECONDS=60
