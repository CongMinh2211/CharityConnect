{
  "openapi": "3.1.0",
  "info": { "title": "CharityConnect Identity Service", "version": "1.0.0" },
  "paths": {
    "/auth/register": { "post": { "summary": "Đăng ký và xếp email chào mừng vào outbox", "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["email", "password", "name", "role", "terms_accepted"], "properties": { "email": { "type": "string", "format": "email" }, "password": { "type": "string" }, "name": { "type": "string" }, "role": { "enum": ["DONOR", "ORGANIZATION"] }, "terms_accepted": { "const": true } } } } } }, "responses": { "201": { "description": "Created; email_notification=QUEUED" }, "400": { "description": "Invalid input" } } } },
    "/auth/login": { "post": { "summary": "Đăng nhập và nhận JWT", "responses": { "200": { "description": "Authenticated" }, "401": { "description": "Invalid credentials" } } } },
    "/auth/google": { "post": { "summary": "Đăng nhập hoặc đăng ký nhanh bằng Google ID token đã xác minh", "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["credential", "terms_accepted"], "properties": { "credential": { "type": "string", "description": "Google ID token từ Google Identity Services" }, "role": { "enum": ["DONOR", "ORGANIZATION"], "default": "DONOR" }, "terms_accepted": { "const": true } } } } } }, "responses": { "200": { "description": "Authenticated" }, "201": { "description": "New Google account created" }, "401": { "description": "Invalid Google credential" }, "503": { "description": "Google Sign-In is not configured" } } } },
    "/auth/set-password": { "post": { "summary": "Tạo mật khẩu cục bộ đầu tiên cho tài khoản Google đã đăng nhập", "security": [{ "bearerAuth": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["new_password"], "properties": { "new_password": { "type": "string", "minLength": 8, "writeOnly": true } } } } } }, "responses": { "201": { "description": "Local password hash created" }, "409": { "description": "Account is not Google-only or already has a local password" } } } },
    "/profile": { "get": { "summary": "Xem hồ sơ", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Profile" } } }, "put": { "summary": "Cập nhật hồ sơ", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Updated" } } } },
    "/admin/users": { "get": { "summary": "Danh sách tài khoản kèm phương thức đăng nhập và phiên đang hoạt động", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "User list without password hash or Google subject" } } } },
    "/admin/users/{id}/profile": { "patch": { "summary": "Admin cập nhật tên/email; đổi email thu hồi mọi phiên", "security": [{ "bearerAuth": [] }], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }], "responses": { "200": { "description": "Updated" }, "409": { "description": "Duplicate email" } } } },
    "/admin/users/{id}/password-reset": { "post": { "summary": "Xếp email đặt lại mật khẩu; không trả token hoặc mật khẩu cho admin", "security": [{ "bearerAuth": [] }], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }], "responses": { "202": { "description": "Reset email queued" } } } },
    "/admin/users/{id}/revoke-sessions": { "post": { "summary": "Đăng xuất tài khoản khỏi mọi thiết bị", "security": [{ "bearerAuth": [] }], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }], "responses": { "200": { "description": "Sessions and refresh tokens revoked atomically" } } } },
    "/admin/users/{id}/status": { "patch": { "summary": "Khóa/mở tài khoản và thu hồi mọi phiên/token", "security": [{ "bearerAuth": [] }], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }], "responses": { "200": { "description": "Status updated and sessions revoked" } } } },
    "/organizations/application": { "post": { "summary": "Nộp hồ sơ xác minh tổ chức", "security": [{ "bearerAuth": [] }], "responses": { "201": { "description": "Submitted" } } } },
    "/organizations/me": { "get": { "summary": "Xem trạng thái tổ chức", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Organization profile" } } } },
    "/admin/organizations": { "get": { "summary": "Hàng đợi xác minh", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Queue" } } } },
    "/admin/organizations/{id}/status": { "patch": { "summary": "Duyệt hoặc từ chối tổ chức", "security": [{ "bearerAuth": [] }], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Reviewed" } } } },
    "/analytics/users/public": { "get": { "summary": "Thống kê công khai số donor và tổ chức đã xác minh", "responses": { "200": { "description": "Public user analytics" } } } },
    "/analytics/users/admin": { "get": { "summary": "Phân bố vai trò và trạng thái tổ chức", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Admin user analytics" } } } }
    ,"/admin/sync/identity": { "get": { "summary": "Identity synchronization status", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "Account, session and email outbox counters" } } } }
    ,"/internal/sessions/{sessionId}/status": { "get": { "summary": "Internal session and user status check", "parameters": [{ "name": "sessionId", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "user_id", "in": "query", "required": true, "schema": { "type": "string" } }, { "name": "x-internal-token", "in": "header", "required": true, "schema": { "type": "string", "writeOnly": true } }], "responses": { "200": { "description": "Session status" }, "401": { "description": "Invalid internal token" } } } }
  },
  "components": { "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" } } }
}
