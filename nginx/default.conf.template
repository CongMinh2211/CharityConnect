upstream identity { server ${IDENTITY_HOSTPORT}; }
upstream campaign { server ${CAMPAIGN_HOSTPORT}; }
upstream donation { server ${DONATION_HOSTPORT}; }
upstream assistant { server ${ASSISTANT_HOSTPORT}; }

limit_req_zone $binary_remote_addr zone=auth_zone:10m rate=10r/m;
limit_req_zone $binary_remote_addr zone=api_zone:10m rate=120r/m;
limit_req_status 429;

server {
  listen ${PORT};
  client_max_body_size 55m;
  server_tokens off;

  add_header X-Content-Type-Options nosniff always;
  add_header X-Frame-Options DENY always;
  add_header Referrer-Policy no-referrer always;
  add_header Access-Control-Allow-Origin "${PUBLIC_WEB_URL}" always;
  add_header Access-Control-Allow-Credentials "true" always;
  add_header Access-Control-Allow-Headers "Authorization,Content-Type" always;
  add_header Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS" always;
  add_header Vary "Origin" always;

  if ($request_method = OPTIONS) { return 204; }
  location = /health { default_type application/json; return 200 '{"status":"ok","service":"gateway"}'; }

  location /api/v1/auth/ { limit_req zone=auth_zone burst=10 nodelay; proxy_pass http://identity/auth/; }
  location = /api/v1/profile { proxy_pass http://identity/profile; }
  location /api/v1/sessions { proxy_pass http://identity/sessions; }
  location /api/v1/me/ { proxy_pass http://identity/me/; }
  location /api/v1/organizations/ { proxy_pass http://identity/organizations/; }
  location = /api/v1/admin/users { proxy_pass http://identity/admin/users; }
  location /api/v1/admin/users/ { proxy_pass http://identity/admin/users/; }
  location = /api/v1/admin/organizations { proxy_pass http://identity/admin/organizations; }
  location /api/v1/admin/organizations/ { proxy_pass http://identity/admin/organizations/; }
  location = /api/v1/admin/audit-logs/identity { proxy_pass http://identity/admin/audit-logs/identity; }
  location /api/v1/analytics/users/ { proxy_pass http://identity/analytics/users/; }
  location = /api/v1/admin/sync/identity { proxy_pass http://identity/admin/sync/identity; }

  location = /api/v1/campaigns { proxy_pass http://campaign/campaigns; }
  location /api/v1/campaigns/ { proxy_pass http://campaign/campaigns/; }
  location /api/v1/organization/campaigns { proxy_pass http://campaign/organization/campaigns; }
  location /api/v1/organization/impact-reports/ { proxy_pass http://campaign/organization/impact-reports/; }
  location /api/v1/admin/campaigns { proxy_pass http://campaign/admin/campaigns; }
  location /api/v1/admin/impact-reports { proxy_pass http://campaign/admin/impact-reports; }
  location /api/v1/admin/reports { proxy_pass http://campaign/admin/reports; }
  location = /api/v1/admin/campaign-risks { proxy_pass http://campaign/admin/campaign-risks; }
  location = /api/v1/admin/audit-logs/campaign { proxy_pass http://campaign/admin/audit-logs/campaign; }
  location /api/v1/reports/ { proxy_pass http://campaign/reports/; }
  location /api/v1/impact-evidence/ { proxy_pass http://campaign/impact-evidence/; }
  location /api/v1/analytics/campaigns/ { proxy_pass http://campaign/analytics/campaigns/; }
  location = /api/v1/admin/sync/campaign { proxy_pass http://campaign/admin/sync/campaign; }

  location = /api/v1/donations { limit_req zone=api_zone burst=30 nodelay; proxy_pass http://donation/donations; }
  location /api/v1/donations/ { proxy_pass http://donation/donations/; }
  location /api/v1/organization/donations/ { proxy_pass http://donation/organization/donations/; }
  location /api/v1/transparency/ { proxy_pass http://donation/transparency/; }
  location /api/v1/admin/transparency/ { proxy_pass http://donation/admin/transparency/; }
  location /api/v1/admin/donations/ { proxy_pass http://donation/admin/donations/; }
  location /api/v1/analytics/donations/ { proxy_pass http://donation/analytics/donations/; }
  location = /api/v1/admin/sync/donation { proxy_pass http://donation/admin/sync/donation; }

  location /api/v1/assistant/ { proxy_pass http://assistant/assistant/; }
  location /api/v1/content/ { proxy_pass http://assistant/content/; }
  location /api/v1/admin/content/ { proxy_pass http://assistant/admin/content/; }
}
